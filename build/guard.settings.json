{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d).on(\"end\",()=>{let cmd=\"\";try{cmd=JSON.parse(s).tool_input.command||\"\"}catch{};const bad=/(\\bgh\\b[^\\n]*(-X|--method)[=\\s]*(POST|PUT|PATCH|DELETE))|(\\bgh\\b(\\s+--?\\S+)*\\s+(pr|issue)\\s+(review|comment|merge|close|reopen|edit|ready|create|update-branch|lock|unlock|delete|pin|unpin|transfer|develop))|\\bmutation\\b|\\/requested_reviewers|\\/replies/i.test(cmd);if(bad){console.log(JSON.stringify({decision:\"block\",reason:\"read-only generation: mutating gh blocked\"}));process.exit(0)}process.exit(0)})'"
          }
        ]
      }
    ]
  }
}
